    "searchLatestChapterRule": "td.odd:nth-child(2) a@text",
    "chapterListRule": "div#list dl dd a",
    "chapterNameRule": "@text",
    "chapterUrlRule": "@href",
    "contentRule": "div#content@html"
  },
