[
  {
    "name": "看漫画 (manhuagui)",
    "baseUrl": "https://m.manhuagui.com",
    "enabled": true,
    "sortOrder": 0,
    "searchUrl": "https://m.manhuagui.com/s/{{keyword}}.html",
    "searchListRule": "ul#detail > li",
    "searchNameRule": "h3@text",
    "searchAuthorRule": "dl:nth-child(1) dd@text",
    "searchCoverRule": "div.thumb img@data-src",
    "searchUrlRule": "a@href",
    "searchStatusRule": "div.thumb i@text",
    "chapterListRule": "div.chapter-list ul li a",
    "chapterNameRule": "@text",
    "chapterUrlRule": "@href",
    "imageListRule": "div.mh_comicpic img@src",
    "searchEncoding": "UTF-8",
    "isBuiltIn": true
  },
  {
    "name": "包子漫画 (baozimh)",
    "baseUrl": "https://www.baozimh.com",
    "enabled": true,
    "sortOrder": 1,
    "searchUrl": "https://www.baozimh.com/search?q={{keyword}}",
    "searchListRule": "div.comics-card",
    "searchNameRule": "h3@text",
    "searchAuthorRule": "small.tags@text",
    "searchCoverRule": "amp-img@src",
    "searchUrlRule": "a.comics-card__poster@href",
    "searchStatusRule": "span.tab@text",
    "chapterListRule": "a.comics-chapters__item",
    "chapterNameRule": "span@text",
    "chapterUrlRule": "@href",
    "imageListRule": "amp-img.comic-contain__item@src",
    "searchEncoding": "UTF-8",
    "isBuiltIn": true
  },
  {
    "name": "漫画猫 (maofly)",
    "baseUrl": "https://www.maofly.com",
    "enabled": false,
    "sortOrder": 2,
    "searchUrl": "https://www.maofly.com/search.html?q={{keyword}}",
    "searchListRule": "div.comic-list-item",
    "searchNameRule": "h3 a@text",
    "searchCoverRule": "img@data-original",
    "searchUrlRule": "h3 a@href",
    "chapterListRule": "ul.chapter-list li a",
    "chapterNameRule": "@text",
    "chapterUrlRule": "@href",
    "imageListRule": "div.rd-article__pic img@data-src",
    "searchEncoding": "UTF-8",
    "isBuiltIn": true
  }
]
